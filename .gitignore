body{
margin:0;
font-family:Arial;
background:#0b1220;
color:white;
overflow-x:hidden;
}

.hero{
padding:60px 20px;
text-align:center;
background:linear-gradient(-45deg,#7c3aed,#ec4899,#3b82f6);
background-size:400% 400%;
animation:grad 10s ease infinite;
}

@keyframes grad{
0%{background-position:0% 50%}
50%{background-position:100% 50%}
100%{background-position:0% 50%}
}

#search{
margin-top:15px;
padding:10px;
width:60%;
max-width:300px;
border:none;
border-radius:8px;
outline:none;
}

section{
padding:50px 20px;
text-align:center;
}

.grid{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:15px;
}

.card{
width:160px;
background:rgba(255,255,255,0.05);
backdrop-filter:blur(10px);
padding:10px;
border-radius:12px;

opacity:0;
transform:translateY(40px);
transition:0.5s ease;
}

.card.show{
opacity:1;
transform:translateY(0);
}

.card:hover{
transform:translateY(-10px) scale(1.05);
}

.card img{
width:100%;
height:120px;
object-fit:cover;
border-radius:10px;
}

.ig{
display:inline-block;
margin-top:8px;
padding:6px 10px;
background:#e1306c;
color:white;
text-decoration:none;
border-radius:6px;
}

footer{
padding:20px;
background:#020617;
}

.modal {
  display: none;
  position: fixed;
  z-index: 999;
  padding-top: 60px;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.9);
}

.modal-content {
  margin: auto;
  display: block;
  max-width: 90%;
  max-height: 85vh;
  border-radius: 10px;
}

.close {
  position: absolute;
  top: 20px;
  right: 35px;
  color: white;
  font-size: 40px;
  cursor: pointer;
}
